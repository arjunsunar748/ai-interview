# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:test123@localhost:5432/ai_interview_db

# ── JWT ───────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ───────────────────────────────────────────────────
APP_NAME=AI Interview Platform
APP_VERSION=1.0.0
DEBUG=True
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── File Storage ──────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── Ollama (Local LLM) ────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Whisper STT ───────────────────────────────────────────
WHISPER_MODEL=base

# ── Admin ─────────────────────────────────────────────────
ADMIN_EMAIL=admin@interview.com
ADMIN_PASSWORD=Admin@123456
